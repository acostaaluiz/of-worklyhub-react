{
  "name": "of-worklyhub-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --port 4173 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "depcruise": "depcruise --config .dependency-cruiser.cjs --include-only \"^src\" src",
    "depcruise:graph": "depcruise --config .dependency-cruiser.cjs --include-only \"^src\" --output-type html src > dependency-graph.html",
    "depcruise:graph:svg": "depcruise --config .dependency-cruiser.cjs --include-only \"^src\" --output-type dot src | dot -T svg > dependency-graph.svg",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "jest --passWithNoTests --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "start-server-and-test dev:e2e http://localhost:4173 cypress:run",
    "cypress:open": "node scripts/run-cypress.mjs open",
    "cypress:run": "node scripts/run-cypress.mjs run",
    "cypress:verify": "node scripts/run-cypress.mjs verify",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache --cache-location .cache/eslint/"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@toast-ui/calendar": "^2.1.3",
    "antd": "^6.1.0",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.3",
    "dotenv": "^17.2.3",
    "firebase": "^12.7.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0",
    "rxjs": "^7.8.2",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.1.1",
    "commitizen": "^4.3.1",
    "cypress": "^14.5.4",
    "cz-git": "^1.12.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "sass": "^1.96.0",
    "start-server-and-test": "^2.1.5",
    "ts-jest": "^29.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}
